<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>杰冉影像工作室 - 自動化請款系統</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
    <style>
        /* A4 紙張的絕對尺寸與防跑版設定 */
        :root {
            --a4-width: 210mm;
            --a4-height: 297mm;
        }
        body { background-color: #f3f4f6; }
        .a4-container {
            width: var(--a4-width);
            height: var(--a4-height);
            background: white;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            padding: 20mm;
            box-sizing: border-box;
            position: relative; /* 讓底部匯款資訊可以絕對定位 */
            overflow: hidden; /* 強制不超過一頁 */
        }
        /* 隱藏捲軸 */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        
        .toast {
            visibility: hidden;
            min-width: 250px;
            background-color: #333;
            color: #fff;
            text-align: center;
            border-radius: 8px;
            padding: 12px;
            position: fixed;
            z-index: 50;
            left: 50%;
            bottom: 30px;
            transform: translateX(-50%);
            opacity: 0;
            transition: opacity 0.3s, bottom 0.3s;
        }
        .toast.show {
            visibility: visible;
            opacity: 1;
            bottom: 50px;
        }
    </style>
</head>
<body class="h-screen flex overflow-hidden font-sans text-gray-800">

    <div class="w-1/2 h-full overflow-y-auto p-8 bg-white border-r">
        <h1 class="text-2xl font-bold mb-6 text-gray-800">請款單設定 (輸入區)</h1>
        
        <div class="grid grid-cols-2 gap-4 mb-6">
            <div>
                <label class="block text-sm font-medium mb-1">廠商公司名稱</label>
                <input type="text" id="clientName" class="w-full border rounded p-2" placeholder="請輸入廠商名稱" oninput="updatePreview()">
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">請款日期</label>
                <input type="date" id="invoiceDate" class="w-full border rounded p-2" oninput="updatePreview()">
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">請款單號</label>
                <input type="text" id="invoiceNo" class="w-full border rounded p-2" placeholder="例如: INV-20260507" oninput="updatePreview()">
            </div>
            <div class="flex items-end pb-2">
                <label class="flex items-center cursor-pointer">
                    <input type="checkbox" id="taxToggle" class="form-checkbox h-5 w-5 text-blue-600" onchange="updatePreview()">
                    <span class="ml-2">包含 5% 營業稅</span>
                </label>
            </div>
        </div>

        <hr class="my-6">

        <div class="mb-4 flex justify-between items-center">
            <h2 class="text-lg font-bold">費用明細</h2>
            <button onclick="addRow()" class="bg-blue-500 text-white px-3 py-1 rounded text-sm hover:bg-blue-600">+ 新增項目</button>
        </div>
        
        <div id="itemsContainer" class="space-y-3 mb-6">
            </div>

        <hr class="my-6">

        <h2 class="text-lg font-bold mb-2">上傳證明附件 (發票、車資證明等)</h2>
        <input type="file" id="fileInput" multiple accept="image/*,application/pdf" class="w-full border p-2 rounded mb-2">
        <p class="text-sm text-gray-500 mb-6">這些檔案在下載時會被打包進同一個 ZIP 資料夾內。</p>

        <button onclick="exportToZip()" class="w-full bg-green-600 text-white font-bold py-3 rounded-lg hover:bg-green-700 transition shadow-lg flex justify-center items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
            打包下載 (PDF + PNG + 附件)
        </button>
    </div>

    <div class="w-1/2 h-full bg-gray-200 flex justify-center overflow-y-auto p-8 relative">
        <div id="invoicePreview" class="a4-container flex flex-col">
            <div class="border-b-2 border-gray-800 pb-4 mb-6 flex justify-between items-end">
                <div>
                    <h1 class="text-3xl font-black text-gray-900 tracking-wider">杰冉影像工作室</h1>
                    <p class="text-sm text-gray-500 tracking-widest mt-1">JAYRAN STUDIO</p>
                </div>
                <div class="text-right text-sm">
                    <p>請款日期：<span id="prevDate"></span></p>
                    <p>單據編號：<span id="prevNo"></span></p>
                </div>
            </div>

            <div class="mb-6">
                <p class="font-bold text-gray-700">致受文者：</p>
                <p class="text-xl font-bold text-gray-900 mt-1 border-b inline-block pb-1 min-w-[200px]" id="prevClient"></p>
            </div>

            <table class="w-full text-left border-collapse mb-6">
                <thead>
                    <tr class="bg-gray-100 border-b-2 border-gray-300">
                        <th class="p-2 w-12 text-center">NO.</th>
                        <th class="p-2">日期</th>
                        <th class="p-2">詳細項目描述</th>
                        <th class="p-2 text-center w-16">數量</th>
                        <th class="p-2 text-right w-24">單價</th>
                        <th class="p-2 text-right w-28">小計</th>
                    </tr>
                </thead>
                <tbody id="prevItems" class="text-sm">
                    </tbody>
            </table>

            <div class="flex-grow"></div>

            <div class="w-full flex justify-end mb-8">
                <div class="w-64">
                    <div class="flex justify-between py-1 border-b">
                        <span class="text-gray-600">小計：</span>
                        <span id="prevSubtotal">NT$ 0</span>
                    </div>
                    <div class="flex justify-between py-1 border-b" id="taxRow" style="display:none;">
                        <span class="text-gray-600">營業稅 (5%)：</span>
                        <span id="prevTax">NT$ 0</span>
                    </div>
                    <div class="flex justify-between py-2 text-lg font-bold">
                        <span>總計金額：</span>
                        <span id="prevTotal">NT$ 0</span>
                    </div>
                </div>
            </div>

            <div class="bg-gray-50 p-4 rounded-lg border border-gray-200 absolute bottom-8 left-8 right-8 cursor-pointer hover:bg-blue-50 transition" onclick="copyBankInfo()" title="點擊複製帳號">
                <p class="font-bold mb-2 flex items-center">
                    【匯款資訊】 <span class="text-xs text-blue-500 ml-2 font-normal">(點擊複製)</span>
                </p>
                <div class="grid grid-cols-2 text-sm">
                    <p>銀行名稱：中國信託 (822)</p>
                    <p>分行名稱：台南分行</p>
                    <p>戶名：杰冉影像工作室 魏敏軒</p>
                    <p>帳號：<span id="bankAccount" class="font-bold tracking-widest text-blue-700">000000000000</span></p>
                </div>
            </div>
        </div>
    </div>

    <div id="toast" class="toast">銀行資訊已複製到剪貼簿！</div>

    <script>
        let items = [];

        // 初始化
        window.onload = () => {
            document.getElementById('invoiceDate').valueAsDate = new Date();
            addRow(); // 預設給一列
            updatePreview();
        };

        // 新增列
        function addRow() {
            if (items.length >= 10) {
                alert("為確保不超過一頁 A4，最多建議新增 10 個項目喔！");
                return;
            }
            const id = Date.now();
            items.push({ id, date: '', desc: '', qty: 1, price: 0 });
            renderInputTable();
            updatePreview();
        }

        // 刪除列
        function removeRow(id) {
            items = items.filter(item => item.id !== id);
            renderInputTable();
            updatePreview();
        }

        // 處理輸入變更
        function handleItemChange(id, field, value) {
            const item = items.find(i => i.id === id);
            if (item) {
                item[field] = field === 'qty' || field === 'price' ? Number(value) : value;
                updatePreview();
            }
        }

        // 渲染左側輸入列
        function renderInputTable() {
            const container = document.getElementById('itemsContainer');
            container.innerHTML = '';
            items.forEach((item, index) => {
                const row = document.createElement('div');
                row.className = "flex gap-2 items-center bg-gray-50 p-2 rounded border";
                row.innerHTML = `
                    <span class="font-bold text-gray-500 w-6 text-center">${index + 1}.</span>
                    <input type="date" class="border rounded p-1 w-32 text-sm" value="${item.date}" oninput="handleItemChange(${item.id}, 'date', this.value)">
                    <input type="text" class="border rounded p-1 flex-grow text-sm" placeholder="項目描述" value="${item.desc}" oninput="handleItemChange(${item.id}, 'desc', this.value)">
                    <input type="number" class="border rounded p-1 w-16 text-sm" placeholder="數量" value="${item.qty}" min="1" oninput="handleItemChange(${item.id}, 'qty', this.value)">
                    <input type="number" class="border rounded p-1 w-24 text-sm" placeholder="單價" value="${item.price}" oninput="handleItemChange(${item.id}, 'price', this.value)">
                    <button onclick="removeRow(${item.id})" class="text-red-500 hover:text-red-700 ml-1">🗑️</button>
                `;
                container.appendChild(row);
            });
        }

        // 格式化金錢
        const formatMoney = (num) => "NT$ " + num.toLocaleString('zh-TW');

        // 更新右側預覽
        function updatePreview() {
            // 基本資訊
            document.getElementById('prevClient').innerText = document.getElementById('clientName').value || "＿＿＿＿＿＿";
            document.getElementById('prevDate').innerText = document.getElementById('invoiceDate').value.replace(/-/g, '/');
            document.getElementById('prevNo').innerText = document.getElementById('invoiceNo').value || "＿＿＿＿＿＿";

            // 表格內容
            const tbody = document.getElementById('prevItems');
            tbody.innerHTML = '';
            let subtotal = 0;

            items.forEach((item, index) => {
                if(!item.desc && item.price === 0) return; // 空的不要顯示
                const rowTotal = item.qty * item.price;
                subtotal += rowTotal;
                
                tbody.innerHTML += `
                    <tr class="border-b border-gray-100">
                        <td class="p-2 text-center text-gray-500">${index + 1}</td>
                        <td class="p-2 text-gray-600">${item.date.replace(/-/g, '/')}</td>
                        <td class="p-2 font-medium">${item.desc}</td>
                        <td class="p-2 text-center">${item.qty}</td>
                        <td class="p-2 text-right">${formatMoney(item.price)}</td>
                        <td class="p-2 text-right font-medium">${formatMoney(rowTotal)}</td>
                    </tr>
                `;
            });

            // 計算金額
            const hasTax = document.getElementById('taxToggle').checked;
            const taxAmount = hasTax ? Math.round(subtotal * 0.05) : 0;
            const grandTotal = subtotal + taxAmount;

            document.getElementById('prevSubtotal').innerText = formatMoney(subtotal);
            document.getElementById('taxRow').style.display = hasTax ? 'flex' : 'none';
            document.getElementById('prevTax').innerText = formatMoney(taxAmount);
            document.getElementById('prevTotal').innerText = formatMoney(grandTotal);
        }

        // 點擊複製銀行資訊
        function copyBankInfo() {
            const info = `【匯款資訊】\n銀行名稱：中國信託 (822) 台南分行\n戶名：杰冉影像工作室 魏敏軒\n帳號：000000000000`;
            navigator.clipboard.writeText(info).then(() => {
                const toast = document.getElementById('toast');
                toast.classList.add('show');
                setTimeout(() => { toast.classList.remove('show'); }, 2500);
            });
        }

        // 打包下載 (PDF + PNG + 附件)
        async function exportToZip() {
            const previewEl = document.getElementById('invoicePreview');
            const clientName = document.getElementById('clientName').value || "廠商";
            const dateStr = document.getElementById('invoiceDate').value.replace(/-/g, '');
            const baseFileName = `杰冉工作室_請款單_${clientName}_${dateStr}`;

            // 1. 擷取 A4 畫面轉 PNG
            const canvas = await html2canvas(previewEl, { scale: 2 }); // 提升解析度
            const imgData = canvas.toDataURL("image/png");

            // 2. 轉存 PDF (A4 尺寸)
            const { jsPDF } = window.jspdf;
            const pdf = new jsPDF('p', 'mm', 'a4');
            const pdfWidth = pdf.internal.pageSize.getWidth();
            const pdfHeight = (canvas.height * pdfWidth) / canvas.width;
            pdf.addImage(imgData, 'PNG', 0, 0, pdfWidth, pdfHeight);
            const pdfBlob = pdf.output('blob');

            // 3. 準備 JSZip
            const zip = new JSZip();
            
            // 加入 PDF 和 PNG
            zip.file(`${baseFileName}.pdf`, pdfBlob);
            zip.file(`${baseFileName}.png`, imgData.split(',')[1], {base64: true});

            // 4. 抓取上傳的附件圖片
            const files = document.getElementById('fileInput').files;
            if (files.length > 0) {
                const imgFolder = zip.folder("相關證明附件");
                for (let i = 0; i < files.length; i++) {
                    imgFolder.file(files[i].name, files[i]);
                }
            }

            // 5. 產出 ZIP 並下載
            zip.generateAsync({type:"blob"}).then(function(content) {
                saveAs(content, `${baseFileName}_完整請款資料.zip`);
            });
        }
    </script>
</body>
</html>
